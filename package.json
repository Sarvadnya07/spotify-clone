{
  "name": "spotify-clone",
  "private": true,
  "version": "0.0.0",
  "_description": "A Spotify-like music streaming interface built with React, Vite, Tailwind, Context API and custom audio controls.",
  "_note": "Comment-style keys use underscore (_) and stay OUTSIDE dependencies/devDependencies.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "clean": "rimraf dist",
    "analyze": "vite --analyze",
    "dev:slow": "vite --force --debug",
    "dev:inspect": "node --inspect-brk node_modules/vite/bin/vite.js"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "_optional_ui_libraries": {
    "chakra_ui": "^2.x",
    "radix_ui": "^1.x",
    "zustand": "^5.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.11",
    "vite": "^7.2.4"
  },
  "_optional_testing": {
    "vitest": "^1.x",
    "testing-library-react": "^14.x"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "_directories": {
    "public": "Static assets",
    "src": "Main React application",
    "components": "UI components",
    "context": "Global providers",
    "assets": "Images, icons",
    "hooks": "Reusable hooks",
    "utils": "Helper functions"
  },
  "keywords": [
    "spotify",
    "spotify-clone",
    "music-player",
    "react",
    "vite",
    "tailwind",
    "audio-player",
    "web-app",
    "frontend",
    "streaming-ui",
    "context-api"
  ],
  "license": "MIT",
  "author": {
    "name": "BROKEN",
    "email": "",
    "url": ""
  },
  "homepage": ".",
  "_future_improvements": {
    "pwa_support": "vite-plugin-pwa",
    "analytics": "posthog or firebase",
    "state_management": "zustand, jotai, redux-toolkit",
    "css_frameworks": "daisyui, shadcn, flowbite",
    "visualizer": "canvas or three.js"
  }
}
